# === IBM watsonx.ai ===
WATSONX_API_KEY=<your-watsonx-api-key>
WATSONX_PROJECT_ID=<your-watsonx-project-id>
WATSONX_URL=https://eu-de.ml.cloud.ibm.com

# === IBM Cloudant ===
CLOUDANT_API_KEY=<your-cloudant-api-key>
CLOUDANT_URL=<your-cloudant-url>
CLOUDANT_DATABASE=startup-funding

# === Granite Model IDs ===
GRANITE_CHAT_MODEL=ibm/granite-4-h-small
GRANITE_EMBEDDING_MODEL=ibm/granite-embedding-278m-multilingual

# === Gemini (optional but recommended — enables model fallbacks when Watsonx quota is exhausted) ===
GEMINI_API_KEY=<your-google-gemini-api-key>

# === Application ===
APP_ENV=development
APP_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data
LOG_LEVEL=INFO
